@page "/rss"

<PageTitle>RSS Feed | Samet Can Cıncık</PageTitle>

<HeadContent>
    <meta name="description" content="Subscribe to RSS or JSON feeds to follow the latest posts, projects, and gists." />
</HeadContent>

<div class="page-container page-section flow-lg">
    <BackToHome />

    <div class="center-stack" style="margin-top: 1rem; margin-bottom: 1.5rem;">
        <h1 class="text-page-title text-gradient">Subscribe to Updates</h1>
        <p class="text-body text-muted" style="max-width: 600px;">
            Stay up-to-date with the latest blog posts, gists, and projects.
            Choose your preferred feed format below.
        </p>
    </div>

    <div class="row wrap" style="align-items: stretch; gap: 1rem; margin-bottom: 1rem;">
        <section class="card card-outline flow" style="flex: 1 1 18rem;">
            <div class="row">
                <AppIcon Name="rss" Class="icon-lg text-primary" />
                <h2 class="text-section-title">RSS Feed</h2>
            </div>
            <p class="text-body text-muted" style="flex: 1 1 auto;">
                        Standard RSS 2.0 format. Compatible with Feedly, Inoreader, and most classic feed readers.
            </p>
            <div class="row">
                <a class="button button-outline button-small" href="/rss.xml" target="_blank" data-umami-event="feed-open-rss-xml-click">Open</a>
            </div>
        </section>
        <section class="card card-outline flow" style="flex: 1 1 18rem;">
            <div class="row">
                <AppIcon Name="code" Class="icon-lg text-muted" />
                <h2 class="text-section-title">JSON Feed</h2>
            </div>
            <p class="text-body text-muted" style="flex: 1 1 auto;">
                        Modern JSON format. Ideal for developers and programmatic consumption of the content.
            </p>
            <div class="row">
                <a class="button button-outline button-small" href="/feed.json" target="_blank" data-umami-event="feed-open-feed-json-click">Open</a>
            </div>
        </section>
    </div>

    <section class="card card-outline flow" style="background: var(--color-surface-muted);">
        <h2 class="text-heading">Quick Start Guide</h2>
        <div class="flow">
            <div class="row" style="align-items: flex-start;">
                <span class="guide-index">1</span>
                <p class="text-body text-muted">
                    Click <b>"Open"</b> to preview the feed in your browser, or copy the URL from the address bar.
                </p>
            </div>
            <div class="row" style="align-items: flex-start;">
                <span class="guide-index">2</span>
                <p class="text-body text-muted">
                    Paste the URL into your favorite feed reader (e.g., Feedly, Inoreader, NetNewsWire).
                </p>
            </div>
        </div>
    </section>
</div>
