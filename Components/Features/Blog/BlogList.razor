@page "/blog"
@inject IContentService ContentService
@inject PersistentComponentState ApplicationState
@implements IDisposable

<PageTitle>Blog | Samet Can Cıncık</PageTitle>

<HeadContent>
    <meta name="description" content="Browse blog posts about web development, .NET, frontend tooling, and practical engineering notes." />
</HeadContent>

<ContentListPage Title="Blog Posts"
                 Description="A collection of my thoughts on development and the passions that keep me inspired."
                 Posts="_posts"
                 UrlPrefix="blog"
                 IsLoading="_loading" />

@code {
    private List<PostModel> _posts = new();
    private bool _loading = true;
    private PersistingComponentStateSubscription? _persistSubscription;

    protected override void OnInitialized()
    {
        if (ApplicationState.TryTakeFromJson<List<PostModel>>(nameof(BlogList), out var posts) && posts is not null)
        {
            _posts = posts;
            _loading = false;
        }

        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistStateAsync);
    }

    protected override async Task OnInitializedAsync()
    {
        if (!_loading)
        {
            return;
        }

        _posts = await ContentService.GetPostsAsync("posts");
        _loading = false;
    }

    private Task PersistStateAsync()
    {
        ApplicationState.PersistAsJson(nameof(BlogList), _posts);
        return Task.CompletedTask;
    }

    public void Dispose() => _persistSubscription?.Dispose();
}
