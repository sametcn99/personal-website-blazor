@page "/gist"
@inject IContentService ContentService
@inject PersistentComponentState ApplicationState
@implements IDisposable

<PageTitle>Gists | Samet Can Cıncık</PageTitle>

<HeadContent>
    <meta name="description" content="Explore quick technical gists, scripts, and short practical development notes." />
</HeadContent>

<ContentListPage Title="Gists"
                 Description="Quick notes and useful scripts."
                 Posts="_posts"
                 UrlPrefix="gist"
                 IsLoading="_loading" />

@code {
    private List<PostModel> _posts = new();
    private bool _loading = true;
    private PersistingComponentStateSubscription? _persistSubscription;

    protected override void OnInitialized()
    {
        if (ApplicationState.TryTakeFromJson<List<PostModel>>(nameof(GistList), out var posts) && posts is not null)
        {
            _posts = posts;
            _loading = false;
        }

        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistStateAsync);
    }

    protected override async Task OnInitializedAsync()
    {
        if (!_loading)
        {
            return;
        }

        // Use metadata-only loading to avoid heavyweight HTML/SearchableText in the list view.
        // This prevents SignalR disconnections caused by oversized payloads (20+ gists × ~100KB HTML each).
        _posts = await ContentService.GetPostMetadataListAsync("gists");
        _loading = false;
    }

    private Task PersistStateAsync()
    {
        ApplicationState.PersistAsJson(nameof(GistList), _posts);
        return Task.CompletedTask;
    }

    public void Dispose() => _persistSubscription?.Dispose();
}
