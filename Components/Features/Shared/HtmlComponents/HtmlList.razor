@if (Ordered)
{
    <ol class="html-list html-list-ordered">
        @ChildContent
    </ol>
}
else
{
    <ul class="html-list html-list-unordered">
        @ChildContent
    </ul>
}

@code {
    [Parameter] public bool Ordered { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
