@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="page-shell">
    <div class="page-content">
        <div class="content-body">
            <div class="page-container">
                @Body
            </div>
        </div>

        @if (!ShouldHideFooter())
        {
            <footer class="footer-area">
                <div class="page-container footer-container">
                    <div class="divider"></div>
                    <nav class="footer-links" aria-label="Footer">
                        <a class="link-muted footer-link" href="/privacy-policy" data-umami-event="footer-privacy-click">Privacy Policy</a>
                        <a class="link-muted footer-link" href="/rss" data-umami-event="footer-rss-click">RSS</a>
                        <a class="link-muted footer-link" href="/readme" data-umami-event="footer-readme-click">README</a>
                    </nav>
                </div>
            </footer>
        }
    </div>
</div>

@code {
    private bool ShouldHideFooter()
    {
        var uri = Navigation.ToBaseRelativePath(Navigation.Uri).ToLowerInvariant();
        return uri.StartsWith("link") || uri.StartsWith("repo") || uri.StartsWith("privacy");
    }
}

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload" data-umami-event="blazor-error-reload-click">Reload</a>
    <button type="button" class="dismiss" data-umami-event="blazor-error-dismiss-click" aria-label="Dismiss error">✕</button>
</div>
