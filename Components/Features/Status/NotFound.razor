@page "/not-found"

<PageTitle>404 | Samet Can Cıncık</PageTitle>

<HeadContent>
    <meta name="description" content="The requested page could not be found. Return to the homepage to continue browsing." />
</HeadContent>

<div class="center-stack status-page">
    <AppIcon Name="report-problem" Class="status-icon text-muted" Decorative="true" />
    <h1 class="text-display">404</h1>
    <h2 class="text-section-title">Page Not Found</h2>
    <p class="text-body text-muted status-copy">
        The page you are looking for does not exist or may have been moved.
    </p>
    <a class="button button-outline" href="/" data-umami-event="not-found-home-click">Return to Home Page</a>
</div>
