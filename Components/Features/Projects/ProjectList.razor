@page "/project"
@inject personal_website_blazor.Core.Application.Abstractions.IContentService ContentService
@inject PersistentComponentState ApplicationState
@implements IDisposable

<PageTitle>Projects | Samet Can Cıncık</PageTitle>

<HeadContent>
    <meta name="description" content="Discover my side projects, experiments, and hands-on software builds." />
</HeadContent>

<ContentListPage Title="Projects"
                 Description="My experiments and side projects."
                 Posts="_posts"
                 UrlPrefix="project"
                 IsLoading="_loading" />

@code {
    private List<PostModel> _posts = new();
    private bool _loading = true;
    private PersistingComponentStateSubscription? _persistSubscription;

    protected override void OnInitialized()
    {
        if (ApplicationState.TryTakeFromJson<List<PostModel>>(nameof(ProjectList), out var posts) && posts is not null)
        {
            _posts = posts;
            _loading = false;
        }

        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistStateAsync);
    }

    protected override async Task OnInitializedAsync()
    {
        if (!_loading)
        {
            return;
        }

        _posts = await ContentService.GetPostsAsync("projects");
        _loading = false;
    }

    private Task PersistStateAsync()
    {
        ApplicationState.PersistAsJson(nameof(ProjectList), _posts);
        return Task.CompletedTask;
    }

    public void Dispose() => _persistSubscription?.Dispose();
}
