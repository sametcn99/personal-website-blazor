@inject IJSRuntime JsRuntime

<div class="code-component-container">
    <div class="code-component-toolbar">
        <div class="code-component-meta">
            <span class="code-component-dot"></span>
            <span class="code-component-language">@GetLanguageLabel()</span>
        </div>

        <button type="button"
                class="icon-button code-copy-button"
                @onclick="CopyToClipboard"
                data-umami-event="code-copy-click"
                title="Copy code"
                aria-label="@(_copied ? "Copied" : "Copy code")">
            <AppIcon Name="@(_copied ? "check" : "copy")" />
        </button>
    </div>
    <div id="@_codeElementId" class="monaco-code-container" style="width: 100%; border-bottom-left-radius: 6px; border-bottom-right-radius: 6px; overflow: hidden; position: relative; min-height: 50px;">
        @* Initial fallback before JS loads *@
        <div class="skeleton" style="width: 100%; height: 100%; position: absolute; top: 0; left: 0; z-index: 1;"></div>
        <pre class="code-component-pre" style="opacity: 0; visibility: hidden;"><code class="@GetLanguageClass()">@Code</code></pre>
    </div>
</div>

@code {
    [Parameter]
    public string Code { get; set; } = string.Empty;

    [Parameter]
    public string Language { get; set; } = string.Empty;

    private string _codeElementId = Guid.NewGuid().ToString();
    private bool _copied;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !string.IsNullOrEmpty(Code))
        {
            try
            {
                await JsRuntime.InvokeVoidAsync("renderMonacoEditor", _codeElementId, Code, Language);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error highlighting code: {ex.Message}");
            }
        }
    }

    private async Task CopyToClipboard()
    {
        try
        {
            await JsRuntime.InvokeVoidAsync("navigator.clipboard.writeText", Code);
            _copied = true;
            StateHasChanged();

            await Task.Delay(1400);

            _copied = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error copying to clipboard: {ex.Message}");
        }
    }

    private string GetLanguageClass()
    {
        if (string.IsNullOrEmpty(Language))
            return "language-plaintext";

        return $"language-{Language.ToLowerInvariant()}";
    }

    private string GetLanguageLabel()
    {
        if (string.IsNullOrWhiteSpace(Language))
        {
            return "Plain Text";
        }

        return Language.ToUpperInvariant();
    }
}
