<svg class="@CssClass"
     viewBox="0 0 24 24"
     fill="none"
     stroke="currentColor"
     stroke-width="2"
     stroke-linecap="round"
     stroke-linejoin="round"
     role="img"
     aria-hidden="@Decorative"
     @attributes="AdditionalAttributes">
    @if (!string.IsNullOrWhiteSpace(Title))
    {
        <title>@Title</title>
    }

    @switch (Name)
    {
        case "search":
            <circle cx="11" cy="11" r="7" />
            <path d="m20 20-3.5-3.5" />
            break;
        case "info":
            <circle cx="12" cy="12" r="9" />
            <path d="M12 10v6" />
            <path d="M12 7h.01" />
            break;
        case "report-problem":
            <path d="M12 3 2.8 19a1 1 0 0 0 .87 1.5h16.66A1 1 0 0 0 21.2 19L12 3Z" />
            <path d="M12 9v4" />
            <path d="M12 17h.01" />
            break;
        case "lock":
            <rect x="5" y="11" width="14" height="10" rx="2" />
            <path d="M8 11V8a4 4 0 1 1 8 0v3" />
            break;
        case "coffee":
            <path d="M4 10h11v4a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4v-4Z" />
            <path d="M15 11h1a2 2 0 1 1 0 4h-1" />
            <path d="M7 4v3" />
            <path d="M10 4v3" />
            <path d="M13 4v3" />
            break;
        case "heart":
            <path d="m12 20-1.3-1.2C5.4 14 2 10.9 2 7.1 2 4.4 4.2 2.2 6.9 2.2c1.6 0 3.2.8 4.1 2.1.9-1.3 2.5-2.1 4.1-2.1 2.7 0 4.9 2.2 4.9 4.9 0 3.8-3.4 6.9-8.7 11.7L12 20Z" />
            break;
        case "download":
            <path d="M12 3v12" />
            <path d="m7 10 5 5 5-5" />
            <path d="M5 21h14" />
            break;
        case "chevron-down":
            <path d="m6 9 6 6 6-6" />
            break;
        case "external-link":
            <path d="M14 5h5v5" />
            <path d="M10 14 19 5" />
            <path d="M19 14v4a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h4" />
            break;
        case "rss":
            <path d="M5 17a2 2 0 1 0 0 .01" />
            <path d="M4 10a10 10 0 0 1 10 10" />
            <path d="M4 4a16 16 0 0 1 16 16" />
            break;
        case "code":
            <path d="m9 18-6-6 6-6" />
            <path d="m15 6 6 6-6 6" />
            break;
        case "plus":
            <path d="M12 5v14" />
            <path d="M5 12h14" />
            break;
        case "minus":
            <path d="M5 12h14" />
            break;
        case "target":
            <circle cx="12" cy="12" r="8" />
            <circle cx="12" cy="12" r="3" />
            <path d="M12 2v2" />
            <path d="M12 20v2" />
            <path d="M2 12h2" />
            <path d="M20 12h2" />
            break;
        case "close":
            <path d="m6 6 12 12" />
            <path d="m18 6-12 12" />
            break;
        case "fullscreen":
            <path d="M8 3H3v5" />
            <path d="M16 3h5v5" />
            <path d="M21 16v5h-5" />
            <path d="M8 21H3v-5" />
            break;
        case "fullscreen-exit":
            <path d="M8 8H3V3" />
            <path d="M16 8h5V3" />
            <path d="M21 16v5h-5" />
            <path d="M8 16H3v5" />
            <path d="M9 9 3 3" />
            <path d="m15 9 6-6" />
            <path d="m15 15 6 6" />
            <path d="m9 15-6 6" />
            break;
        case "copy":
            <rect x="9" y="9" width="11" height="11" rx="2" />
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
            break;
        case "check":
            <path d="m5 13 4 4L19 7" />
            break;
        case "chevron-left":
            <path d="m15 18-6-6 6-6" />
            break;
        case "chevron-right":
            <path d="m9 18 6-6-6-6" />
            break;
        default:
            <circle cx="12" cy="12" r="9" />
            <path d="M12 8v8" />
            <path d="M8 12h8" />
            break;
    }
</svg>

@code {
    [Parameter] public string Name { get; set; } = string.Empty;
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public bool Decorative { get; set; } = true;
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => string.IsNullOrWhiteSpace(Class) ? "app-icon" : $"app-icon {Class}";
}