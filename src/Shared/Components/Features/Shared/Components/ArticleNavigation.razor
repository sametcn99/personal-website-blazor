@* ArticleNavigation.razor - Previous/Next/Random article navigation *@

@if (PrevArticle != null || NextArticle != null)
{
    <div class="article-nav-row">
        @if (PrevArticle != null)
        {
            <div class="article-nav-card">
                <a class="article-nav-link" href="@PrevArticle.Href"
                   data-umami-event='@UmamiEvent.Click("article-nav-prev", PrevArticle.Title)'>
                    <AppIcon Name="chevron-left" Class="text-primary" />
                    <div class="flow-sm">
                        <span class="text-caption text-muted">@PrevLabel</span>
                        <span class="text-body">@PrevArticle.Title</span>
                    </div>
                </a>
            </div>
        }

        @if (NextArticle != null)
        {
            <div class="article-nav-card article-nav-next">
                <a class="article-nav-link" href="@NextArticle.Href"
                   data-umami-event='@UmamiEvent.Click("article-nav-next", NextArticle.Title)'>
                    <div class="flow-sm">
                        <span class="text-caption text-muted">@NextLabel</span>
                        <span class="text-body">@NextArticle.Title</span>
                    </div>
                    <AppIcon Name="chevron-right" Class="text-primary" />
                </a>
            </div>
        }
    </div>
}

@if (RandomArticle != null)
{
    <div class="article-nav-row" style="margin-top: 0.5rem;">
        <div class="article-nav-card article-nav-random">
            <a class="article-nav-link article-nav-random-link" href="@RandomArticle.Href"
               data-umami-event='@UmamiEvent.Click("article-nav-random", RandomArticle.Title)'>
                <AppIcon Name="shuffle" Class="text-primary" />
                <span class="text-caption text-muted">Random</span>
                <span class="text-body">@RandomArticle.Title</span>
            </a>
        </div>
    </div>
}

@code {
    [Parameter] public ArticleRef? PrevArticle { get; set; }
    [Parameter] public ArticleRef? NextArticle { get; set; }
    [Parameter] public ArticleRef? RandomArticle { get; set; }
    [Parameter] public string PrevLabel { get; set; } = "Previous";
    [Parameter] public string NextLabel { get; set; } = "Next";

    public class ArticleRef
    {
        public string Href { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
    }
}
