@switch (Tag)
{
    case "h1":
        <h1 class="html-heading html-heading-h1">@ChildContent</h1>
        break;
    case "h2":
        <h2 class="html-heading html-heading-h2">@ChildContent</h2>
        break;
    case "h3":
        <h3 class="html-heading html-heading-h3">@ChildContent</h3>
        break;
    case "h4":
        <h4 class="html-heading html-heading-h4">@ChildContent</h4>
        break;
    case "h5":
        <h5 class="html-heading html-heading-h5">@ChildContent</h5>
        break;
    case "h6":
        <h6 class="html-heading html-heading-h6">@ChildContent</h6>
        break;
    default:
        <p class="html-paragraph">@ChildContent</p>
        break;
}

@code {
    [Parameter] public string Tag { get; set; } = "p";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
