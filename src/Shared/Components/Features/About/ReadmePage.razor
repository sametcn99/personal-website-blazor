@page "/readme"
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@inject IJSRuntime Runtime
@inject PersistentComponentState ApplicationState
@implements IDisposable

<PageTitle>README | Samet Can Cıncık</PageTitle>

<HeadContent>
    <meta name="description" content="Read my GitHub profile README with background, interests, and current focus areas." />
</HeadContent>

<MudContainer  >
    <BackToHome />

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
    }
    else if (_error != null)
    {
        <MudAlert Severity="Severity.Error" Class="mt-4">@_error</MudAlert>
    }
    else
    {
        <article class="mt-4">
            <MudHtmlRenderer HtmlContent="@_htmlContent" />
        </article>
    }
</MudContainer>

@code {
    private bool _loading = true;
    private string? _error;
    private string _htmlContent = string.Empty;
    private bool _contentInitialized;
    private PersistingComponentStateSubscription? _persistSubscription;

    protected override void OnInitialized()
    {
        if (ApplicationState.TryTakeFromJson<ReadmeState>(nameof(ReadmePage), out var state) && state is not null)
        {
            _htmlContent = state.HtmlContent;
            _error = state.Error;
            _loading = string.IsNullOrWhiteSpace(_htmlContent);
        }

        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistStateAsync);
    }

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(_htmlContent))
        {
            return;
        }

        try
        {
            _loading = true;
            _error = null;

            var client = HttpClientFactory.CreateClient();
            var requestUri = NavigationManager.ToAbsoluteUri("api/readme");
            var response = await client.GetFromJsonAsync<ReadmeResponse>(requestUri);
            _htmlContent = response?.Html ?? string.Empty;
        }
        catch (Exception ex)
        {
            _error = $"Failed to fetch README: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_contentInitialized || string.IsNullOrWhiteSpace(_htmlContent))
        {
            return;
        }

        try
        {
            await Runtime.InvokeVoidAsync("initContent");
            _contentInitialized = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"JS Error: {ex.Message}");
        }
    }

    private sealed class ReadmeResponse
    {
        public string Html { get; set; } = string.Empty;
    }

    private Task PersistStateAsync()
    {
        ApplicationState.PersistAsJson(nameof(ReadmePage), new ReadmeState
        {
            HtmlContent = _htmlContent,
            Error = _error,
        });

        return Task.CompletedTask;
    }

    public void Dispose() => _persistSubscription?.Dispose();

    private sealed class ReadmeState
    {
        public string HtmlContent { get; set; } = string.Empty;
        public string? Error { get; set; }
    }
}
