@* PostsList.razor - Renders a list of posts in the home page *@

@foreach (var post in Posts)
{
    <a class="link-plain post-card-link" href="@post.Href" data-umami-event='@UmamiEvent.ClickValue(post.Title, "post")'>
        <article class="hover-card post-card flow-sm" style="margin-bottom: 0.75rem;">
            <p class="text-heading">@post.Title</p>
            <p class="text-body text-muted">@post.Summary</p>
            <p class="text-caption text-muted">
                @FormatDate(post.PublishedAt)
            </p>
        </article>
    </a>
}

@code {
    [Parameter] public List<ContentMetadata> Posts { get; set; } = new();

    private static string FormatDate(string dateStr)
    {
        if (DateTime.TryParse(dateStr, out var d))
            return d.ToString("ddd MMM dd yyyy");
        return dateStr;
    }
}
