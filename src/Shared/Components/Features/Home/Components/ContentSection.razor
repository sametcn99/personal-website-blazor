@* ContentSection.razor - Section with title, description, posts, and "See All" button *@

<section class="flow mb-section">
    <div class="row-between wrap">
        <h2 class="text-section-title">@Title</h2>
        @if (Total > Posts.Count)
        {
            <a class="button button-outline button-small" href="@ViewAllHref" data-umami-event="content-section-see-all-click">See All (@Total)</a>
        }
    </div>
    <p class="text-body text-muted">@Description</p>
    <PostsList Posts="Posts" />
</section>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public List<ContentMetadata> Posts { get; set; } = new();
    [Parameter] public int Total { get; set; }
    [Parameter] public string ViewAllHref { get; set; } = string.Empty;
}
