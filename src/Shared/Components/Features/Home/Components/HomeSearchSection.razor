@implements IAsyncDisposable
@using System.Text.Json.Serialization
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@inject NavigationManager Navigation

<section class="flow mb-section home-section">
    <h2 class="text-section-title">Search</h2>
    <div class="flow home-search-panel">
        <div class="input-shell search-input-shell">
            <AppIcon Name="search" />
            <input id="home-search-input"
                   class="input-native"
                   @bind="_searchQuery"
                   @bind:event="oninput"
                   @bind:after="HandleSearchInputChanged"
                   placeholder="Search posts, links, and repositories..."
                   data-umami-event="home-search-input-click" />
        </div>

        @if (_isSearching)
        {
            <div class="row text-muted" style="margin-top: 0.5rem;">
                <div class="spinner"></div>
                <span class="text-caption">Searching...</span>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_searchQuery) && !_isSearching)
        {
            @if (_filteredResults.Count > 0)
            {
                <div class="posts-stack">
                    @foreach (var item in _filteredResults)
                    {
                        <a class="link-plain post-card-link"
                           href="@item.Href"
                           target="@(item.External ? "_blank" : null)"
                           rel="@(item.External ? "noreferrer noopener" : null)"
                           data-umami-event='@UmamiEvent.Click("search-result", item.Title)'>
                            <article class="hover-card post-card flow-sm" style="margin-bottom: 0.75rem;">
                                <p class="text-heading">@item.Title</p>
                                @if (!string.IsNullOrWhiteSpace(item.MatchSnippet))
                                {
                                    <p class="text-caption text-muted" style="opacity: 0.85; line-height: 1.4;"><i>@item.MatchSnippet</i></p>
                                }
                                else if (!string.IsNullOrWhiteSpace(item.Summary))
                                {
                                    <p class="text-body text-muted">@item.Summary</p>
                                }
                                <p class="text-caption text-muted">
                                    @item.TypeLabel@GetDateSummary(item)
                                </p>
                            </article>
                        </a>
                    }
                </div>
            }
            else
            {
                <p class="text-body text-muted search-empty-state">No results found.</p>
            }
        }
    </div>
</section>

@code {
    private const int MaxSearchResults = 10;
    private const int DebounceMs = 250;

    [Parameter] public List<ContentMetadata> BlogPosts { get; set; } = new();
    [Parameter] public List<ContentMetadata> GistPosts { get; set; } = new();
    [Parameter] public List<ContentMetadata> ProjectPosts { get; set; } = new();

    private bool _isSearching;
    private bool _repoFetchStarted;
    private bool _hotkeyRegistered;
    private string _searchQuery = string.Empty;
    private CancellationTokenSource? _debounceCts;
    private readonly List<SearchEntry> _localSearchSource = new();
    private readonly Dictionary<string, SearchEntry> _searchIndexByHref = new(StringComparer.OrdinalIgnoreCase);
    private List<SearchEntry> _filteredResults = new();
    private DotNetObjectReference<HomeSearchSection>? _dotNetRef;
    private string _contentHash = string.Empty;

    protected override void OnParametersSet()
    {
        var nextHash = $"{BlogPosts.Count}:{GistPosts.Count}:{ProjectPosts.Count}";
        if (string.Equals(_contentHash, nextHash, StringComparison.Ordinal))
        {
            return;
        }

        _contentHash = nextHash;
        _localSearchSource.Clear();
        _searchIndexByHref.Clear();

        BuildLocalSearchSource(BlogPosts, "Blog");
        BuildLocalSearchSource(GistPosts, "Gist");
        BuildLocalSearchSource(ProjectPosts, "Project");

        foreach (var link in SocialData.Links)
        {
            AddSearchEntry(new SearchEntry
            {
                Title = link.Label,
                Summary = link.Category,
                Href = link.Link,
                TypeLabel = "Link",
                External = link.External,
            });
        }

        if (!string.IsNullOrWhiteSpace(_searchQuery))
        {
            _ = PerformSearchAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_hotkeyRegistered)
        {
            return;
        }

        _dotNetRef ??= DotNetObjectReference.Create(this);

        try
        {
            await JS.InvokeVoidAsync("registerHomeSearchKeyHandler", _dotNetRef);
            _hotkeyRegistered = true;
        }
        catch (InvalidOperationException)
        {
        }
        catch (JSDisconnectedException)
        {
        }
    }

    [JSInvokable]
    public async Task HandleGlobalKeyInput(string key, bool ctrlKey, bool metaKey, bool altKey)
    {
        if (ctrlKey || metaKey || altKey)
        {
            return;
        }

        if (key == "Escape")
        {
            await ClearSearchAsync();
            return;
        }

        if (key == "Backspace")
        {
            if (_searchQuery.Length == 0)
            {
                return;
            }

            _searchQuery = _searchQuery[..^1];
            DebounceSearch();
            await FocusSearchInputAsync();
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (key.Length == 1)
        {
            _searchQuery += key;

            if (!_repoFetchStarted && _searchQuery.Length > 0)
            {
                _ = LoadRepositoriesAsync();
            }

            DebounceSearch();
            await FocusSearchInputAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private Task OnSearchQueryChanged(string? value)
    {
        _searchQuery = value ?? string.Empty;

        if (!_repoFetchStarted && _searchQuery.Length > 0)
        {
            _ = LoadRepositoriesAsync();
        }

        DebounceSearch();
        return Task.CompletedTask;
    }

    private Task HandleSearchInputChanged() => OnSearchQueryChanged(_searchQuery);

    private void DebounceSearch()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _debounceCts = new CancellationTokenSource();

        var token = _debounceCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(DebounceMs, token);
                if (!token.IsCancellationRequested)
                {
                    await PerformSearchAsync();
                }
            }
            catch (OperationCanceledException)
            {
            }
        });
    }

    private async Task PerformSearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            _filteredResults.Clear();
            await InvokeAsync(StateHasChanged);
            return;
        }

        _isSearching = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var client = HttpClientFactory.CreateClient();
            var searchUrl = Navigation.ToAbsoluteUri($"/api/content/search?q={Uri.EscapeDataString(_searchQuery)}");

            List<SearchResultDto>? apiResults = null;
            try
            {
                apiResults = await client.GetFromJsonAsync<List<SearchResultDto>>(searchUrl);
            }
            catch
            {
            }

            _searchIndexByHref.Clear();
            _localSearchSource.Clear();
            _filteredResults.Clear();

            if (apiResults != null)
            {
                foreach (var r in apiResults)
                {
                    AddSearchEntry(new SearchEntry
                    {
                        Title = r.Title ?? string.Empty,
                        Summary = r.Summary ?? string.Empty,
                        Href = r.Href ?? string.Empty,
                        TypeLabel = r.TypeLabel ?? string.Empty,
                        PublishedAt = r.PublishedAt,
                        UpdatedAt = r.UpdatedAt,
                        MatchSnippet = r.MatchSnippet ?? string.Empty,
                        Tags = r.Tags ?? Array.Empty<string>(),
                    });
                }
            }

            foreach (var link in SocialData.Links)
            {
                var q = _searchQuery;
                if (q.Length > 0 && (
                    link.Label.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                    link.Category.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                    link.Link.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                    Array.Exists(link.Type, t => t.Contains(q, StringComparison.OrdinalIgnoreCase))))
                {
                    AddSearchEntry(new SearchEntry
                    {
                        Title = link.Label,
                        Summary = link.Category,
                        Href = link.Link,
                        TypeLabel = "Link",
                        External = link.External,
                    });
                }
            }

            if (_repoFetchStarted)
            {
                ApplyRepoContentFilter();
            }

            _filteredResults = _localSearchSource.Take(MaxSearchResults).ToList();
        }
        finally
        {
            _isSearching = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ClearSearchAsync()
    {
        _searchQuery = string.Empty;
        _filteredResults.Clear();
        _debounceCts?.Cancel();
        await FocusSearchInputAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task FocusSearchInputAsync()
    {
        if (!_hotkeyRegistered)
        {
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("focusElementById", "home-search-input");
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private void BuildLocalSearchSource(List<ContentMetadata> items, string typeLabel)
    {
        foreach (var item in items)
        {
            AddSearchEntry(new SearchEntry
            {
                Title = item.Title,
                Summary = item.Summary,
                Href = item.Href,
                TypeLabel = typeLabel,
                PublishedAt = item.PublishedAt,
                UpdatedAt = item.UpdatedAt,
            });
        }
    }

    private async Task LoadRepositoriesAsync()
    {
        if (_repoFetchStarted)
        {
            return;
        }

        _repoFetchStarted = true;

        try
        {
            var client = HttpClientFactory.CreateClient();
            var reposApiUrl = Navigation.ToAbsoluteUri("/api/repos");
            var repos = await client.GetFromJsonAsync<List<GitHubRepoDto>>(reposApiUrl);

            if (repos is null)
            {
                return;
            }

            foreach (var repo in repos)
            {
                if (string.IsNullOrWhiteSpace(repo.HtmlUrl) || string.IsNullOrWhiteSpace(repo.Name))
                {
                    continue;
                }

                AddSearchEntry(new SearchEntry
                {
                    Title = repo.Name,
                    Summary = repo.Description ?? string.Empty,
                    Href = repo.HtmlUrl,
                    TypeLabel = "Repository",
                    UpdatedAt = repo.UpdatedAt?.ToString("yyyy-MM-dd"),
                    External = true,
                });
            }
        }
        catch
        {
            _repoFetchStarted = false;
        }
        finally
        {
            if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                ApplyRepoContentFilter();
                _filteredResults = _localSearchSource.Take(MaxSearchResults).ToList();
            }

            await InvokeAsync(StateHasChanged);
        }
    }

    private void ApplyRepoContentFilter()
    {
        var repoEntries = _localSearchSource
            .Where(e => e.TypeLabel == "Repository")
            .Where(e =>
                e.Title.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                e.Summary.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
            .ToList();

        _localSearchSource.RemoveAll(e => e.TypeLabel == "Repository");

        foreach (var repo in repoEntries)
        {
            var href = repo.Href;
            if (!_searchIndexByHref.ContainsKey(href))
            {
                _searchIndexByHref[href] = repo;
                _localSearchSource.Add(repo);
            }
        }
    }

    private void AddSearchEntry(SearchEntry entry)
    {
        if (string.IsNullOrWhiteSpace(entry.Href) || _searchIndexByHref.ContainsKey(entry.Href))
        {
            return;
        }

        _searchIndexByHref[entry.Href] = entry;
        _localSearchSource.Add(entry);
    }

    private static string GetDateSummary(SearchEntry item)
    {
        if (!string.IsNullOrWhiteSpace(item.UpdatedAt))
        {
            return $" · Updated {item.UpdatedAt}";
        }

        if (!string.IsNullOrWhiteSpace(item.PublishedAt))
        {
            return $" · Published {item.PublishedAt}";
        }

        return string.Empty;
    }

    public async ValueTask DisposeAsync()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();

        if (_hotkeyRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("unregisterHomeSearchKeyHandler");
            }
            catch (JSDisconnectedException)
            {
            }
        }

        _dotNetRef?.Dispose();
    }

    private sealed class SearchEntry
    {
        public string Title { get; set; } = string.Empty;
        public string Summary { get; set; } = string.Empty;
        public string Href { get; set; } = string.Empty;
        public string TypeLabel { get; set; } = string.Empty;
        public string? PublishedAt { get; set; }
        public string? UpdatedAt { get; set; }
        public bool External { get; set; }
        public string MatchSnippet { get; set; } = string.Empty;
        public string[] Tags { get; set; } = Array.Empty<string>();
    }

    private sealed class GitHubRepoDto
    {
        [JsonPropertyName("name")]
        public string? Name { get; set; }

        [JsonPropertyName("description")]
        public string? Description { get; set; }

        [JsonPropertyName("html_url")]
        public string? HtmlUrl { get; set; }

        [JsonPropertyName("updated_at")]
        public DateTime? UpdatedAt { get; set; }
    }

    private sealed class SearchResultDto
    {
        [JsonPropertyName("title")]
        public string? Title { get; set; }

        [JsonPropertyName("summary")]
        public string? Summary { get; set; }

        [JsonPropertyName("href")]
        public string? Href { get; set; }

        [JsonPropertyName("typeLabel")]
        public string? TypeLabel { get; set; }

        [JsonPropertyName("publishedAt")]
        public string? PublishedAt { get; set; }

        [JsonPropertyName("updatedAt")]
        public string? UpdatedAt { get; set; }

        [JsonPropertyName("matchSnippet")]
        public string? MatchSnippet { get; set; }

        [JsonPropertyName("tags")]
        public string[]? Tags { get; set; }
    }
}