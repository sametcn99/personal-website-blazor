@page "/repo/{Slug}"
@using System.Text.Json.Serialization
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject PersistentComponentState ApplicationState
@implements IDisposable

<PageTitle>@(_repoName ?? "Redirecting") | Samet Can Cıncık</PageTitle>

<HeadContent>
    <meta name="description" content="@(_repoName is null ? "Redirecting to repository page." : $"Redirecting to {_repoName} on GitHub.")" />
</HeadContent>

@if (_notFound)
{
    <MudContainer   Class="py-8">
        <BackToHome />
        <MudAlert Severity="Severity.Warning" Class="mt-4">Repository not found.</MudAlert>
    </MudContainer>
}
else if (_repoUrl != null)
{
    <RedirectPage TargetUrl="@_repoUrl" />
}
else
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="mt-16">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </MudStack>
}

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private string? _repoUrl;
    private string? _repoName;
    private bool _notFound;
    private string? _loadedSlug;
    private PersistingComponentStateSubscription? _persistSubscription;

    protected override void OnInitialized()
    {
        if (ApplicationState.TryTakeFromJson<RepoRedirectState>(GetStateKey(), out var state) && state is not null)
        {
            _repoUrl = state.RepoUrl;
            _repoName = state.RepoName;
            _notFound = state.NotFound;
        }

        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistStateAsync);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.Equals(_loadedSlug, Slug, StringComparison.Ordinal))
        {
            _repoUrl = null;
            _repoName = null;
            _notFound = false;
            _loadedSlug = null;

            if (ApplicationState.TryTakeFromJson<RepoRedirectState>(GetStateKey(), out var state) && state is not null)
            {
                _repoUrl = state.RepoUrl;
                _repoName = state.RepoName;
                _notFound = state.NotFound;
                _loadedSlug = Slug;
            }
        }

        if (_notFound || !string.IsNullOrWhiteSpace(_repoUrl))
        {
            return;
        }

        try
        {
            var client = HttpClientFactory.CreateClient();
            var requestUri = new Uri(new Uri(Navigation.BaseUri), $"api/repos/{Uri.EscapeDataString(Slug)}");
            var repo = await client.GetFromJsonAsync<RepoData>(requestUri);
            if (repo != null)
            {
                _repoUrl = repo.HtmlUrl;
                _repoName = repo.FullName;
                _loadedSlug = Slug;
                return;
            }
        }
        catch (HttpRequestException) { }
        catch (NotSupportedException) { }

        _notFound = true;
        _loadedSlug = Slug;
    }

    private class RepoData
    {
        [JsonPropertyName("html_url")]
        public string HtmlUrl { get; set; } = string.Empty;

        [JsonPropertyName("full_name")]
        public string FullName { get; set; } = string.Empty;
    }

    private string GetStateKey() => $"{nameof(RepoRedirect)}:{Slug}";

    private Task PersistStateAsync()
    {
        ApplicationState.PersistAsJson(GetStateKey(), new RepoRedirectState
        {
            RepoUrl = _repoUrl,
            RepoName = _repoName,
            NotFound = _notFound,
        });

        return Task.CompletedTask;
    }

    public void Dispose() => _persistSubscription?.Dispose();

    private sealed class RepoRedirectState
    {
        public string? RepoUrl { get; set; }
        public string? RepoName { get; set; }
        public bool NotFound { get; set; }
    }
}
