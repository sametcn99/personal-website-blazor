@page "/repo"
@inject IGitHubService GitHubService
@inject PersistentComponentState ApplicationState
@implements IDisposable

<PageTitle>Repositories | Samet Can Cıncık</PageTitle>

<HeadContent>
    <meta name="description" content="See my public GitHub repositories with live data and quick access links." />
</HeadContent>

<div class="page-container page-section">
    <BackToHome />
    <h1 class="text-page-title">Repositories</h1>
    <p class="text-body text-muted" style="margin-bottom: 0.75rem;">
        A live list of my GitHub repositories.
    </p>

    @if (_loading)
    {
        <div class="center-stack" style="padding: 2rem 0;">
            <div class="spinner"></div>
            <p class="text-caption text-muted">Loading repositories...</p>
        </div>
    }
    else if (_error != null)
    {
        <div class="alert alert-error">@_error</div>
    }
    else
    {
        <InteractiveRepoList Repos="_repos" />
    }
</div>

@code {
    private bool _loading = true;
    private string? _error;
    private List<GitHubRepository> _repos = new();
    private PersistingComponentStateSubscription? _persistSubscription;

    protected override void OnInitialized()
    {
        if (ApplicationState.TryTakeFromJson<RepoListState>(nameof(RepoList), out var state) && state is not null)
        {
            _repos = state.Repos;
            _error = state.Error;
            _loading = false;
        }

        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistStateAsync);
    }

    protected override async Task OnInitializedAsync()
    {
        if (!_loading)
        {
            return;
        }

        try
        {
            var repos = await GitHubService.GetUserRepositoriesAsync("sametcn99", 100);
            _repos = repos.Where(r => !r.Fork).OrderByDescending(r => r.UpdatedAt).ToList();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load repositories: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private Task PersistStateAsync()
    {
        ApplicationState.PersistAsJson(nameof(RepoList), new RepoListState
        {
            Repos = _repos,
            Error = _error,
        });

        return Task.CompletedTask;
    }

    public void Dispose() => _persistSubscription?.Dispose();

    private sealed class RepoListState
    {
        public List<GitHubRepository> Repos { get; set; } = [];
        public string? Error { get; set; }
    }
}
