@rendermode InteractiveWebAssembly

<Router AppAssembly="typeof(Routes).Assembly" OnNavigateAsync="HandleNavigateAsync">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)" />
    </Found>
    <Navigating>
        <div class="page-container route-loading-shell">
            <div class="center-stack route-loading-state">
                <div class="spinner spinner-lg"></div>
                <p class="text-caption text-muted">Loading page...</p>
            </div>
        </div>
    </Navigating>
</Router>

@code {
    private static Task HandleNavigateAsync(NavigationContext context)
        => Task.CompletedTask;
}
